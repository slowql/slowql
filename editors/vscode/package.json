{
  "name": "slowql-vscode",
  "displayName": "SlowQL",
  "description": "VS Code extension for SlowQL LSP diagnostics",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sql",
        "aliases": ["SQL", "sql"],
        "extensions": [".sql"]
      }
    ],
    "commands": [
      {
        "command": "slowql.restartLanguageServer",
        "title": "SlowQL: Restart Language Server"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SlowQL",
      "properties": {
        "slowql.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the SlowQL language server"
        },
        "slowql.command": {
          "type": "string",
          "default": "python",
          "description": "Command used to launch the SlowQL language server"
        },
        "slowql.args": {
          "type": "array",
          "default": ["-m", "slowql.lsp.server"],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the SlowQL language server command"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^20.5.0",
    "@types/vscode": "^1.80.0"
  }
}
