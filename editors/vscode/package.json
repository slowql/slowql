{
  "name": "slowql-vscode",
  "displayName": "SlowQL",
  "description": "VS Code extension for SlowQL LSP diagnostics",
  "version": "0.1.0",
  "publisher": "makroumi",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "badges": [],
  "markdown": "github",
  "qna": "marketplace",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/makroumi/slowql"
  },
  "homepage": "https://github.com/makroumi/slowql",
  "bugs": {
    "url": "https://github.com/makroumi/slowql/issues"
  },
  "keywords": [
    "sql",
    "linter",
    "static-analysis",
    "database",
    "diagnostics",
    "postgresql",
    "mysql"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onCommand:slowql.restartLanguageServer",
    "onCommand:slowql.showStatus",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sql",
        "aliases": ["SQL", "sql"],
        "extensions": [".sql"]
      }
    ],
    "commands": [
      {
        "command": "slowql.restartLanguageServer",
        "title": "SlowQL: Restart Language Server"
      },
      {
        "command": "slowql.showStatus",
        "title": "SlowQL: Show Extension Status"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SlowQL",
      "properties": {
        "slowql.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the SlowQL language server"
        },
        "slowql.command": {
          "type": "string",
          "default": "python",
          "description": "Command used to launch the SlowQL language server"
        },
        "slowql.args": {
          "type": "array",
          "default": ["-m", "slowql.lsp.server"],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the SlowQL language server command"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "clean": "rm -rf out *.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^20.5.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1"
  }
}
