{
  "name": "slowql-vscode",
  "displayName": "SlowQL: Offline SQL Static Analyzer",
  "description": "272 rules, 14 dialects. Catch SQL security, performance, reliability, compliance, cost, and quality issues as you type. No database connection required.",
  "version": "0.2.0",
  "publisher": "makroumi",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/pypi/v/slowql?label=SlowQL%20CLI",
      "href": "https://pypi.org/project/slowql/",
      "description": "SlowQL CLI version"
    }
  ],
  "markdown": "github",
  "qna": "marketplace",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/makroumi/slowql"
  },
  "homepage": "https://github.com/makroumi/slowql",
  "bugs": {
    "url": "https://github.com/makroumi/slowql/issues"
  },
  "keywords": [
    "sql",
    "linter",
    "static-analysis",
    "database",
    "diagnostics",
    "postgresql",
    "mysql",
    "oracle",
    "sqlite",
    "snowflake",
    "bigquery",
    "redshift",
    "clickhouse",
    "duckdb",
    "sql-server",
    "tsql",
    "presto",
    "trino",
    "spark",
    "databricks",
    "security",
    "performance",
    "compliance",
    "gdpr",
    "sql-injection",
    "code-quality"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onCommand:slowql.restartLanguageServer",
    "onCommand:slowql.showStatus",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sql",
        "aliases": ["SQL", "sql"],
        "extensions": [".sql"]
      }
    ],
    "commands": [
      {
        "command": "slowql.restartLanguageServer",
        "title": "SlowQL: Restart Language Server",
        "icon": "$(refresh)"
      },
      {
        "command": "slowql.showStatus",
        "title": "SlowQL: Show Status",
        "icon": "$(info)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SlowQL",
      "properties": {
        "slowql.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the SlowQL language server.",
          "order": 1
        },
        "slowql.dialect": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "postgresql",
            "mysql",
            "tsql",
            "oracle",
            "sqlite",
            "snowflake",
            "bigquery",
            "redshift",
            "clickhouse",
            "duckdb",
            "presto",
            "trino",
            "spark",
            "databricks"
          ],
          "enumDescriptions": [
            "Auto-detect dialect",
            "PostgreSQL",
            "MySQL / MariaDB",
            "SQL Server (T-SQL)",
            "Oracle Database",
            "SQLite",
            "Snowflake",
            "Google BigQuery",
            "Amazon Redshift",
            "ClickHouse",
            "DuckDB",
            "Presto",
            "Trino",
            "Apache Spark SQL",
            "Databricks SQL"
          ],
          "description": "SQL dialect for dialect-specific rule filtering. Leave empty for auto-detection.",
          "order": 2
        },
        "slowql.command": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python executable used to launch the SlowQL language server.",
          "order": 3
        },
        "slowql.args": {
          "type": "array",
          "default": ["-m", "slowql.lsp.server"],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the language server command.",
          "order": 4
        },
        "slowql.schemaFile": {
          "type": "string",
          "default": "",
          "description": "Path to a DDL schema file (.sql) for schema-aware validation. Absolute path or relative to workspace root.",
          "order": 5
        },
        "slowql.databaseUrl": {
          "type": "string",
          "default": "",
          "description": "Database connection string for live schema inference (e.g., postgresql://user:pass@localhost:5432/mydb).",
          "order": 6
        },
        "slowql.trace.server": {
          "type": "string",
          "default": "off",
          "enum": ["off", "messages", "verbose"],
          "description": "Trace communication between VS Code and the SlowQL language server.",
          "order": 7
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "clean": "rm -rf out *.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/node": "^20.5.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1"
  }
}
